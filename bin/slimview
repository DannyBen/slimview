#!/usr/bin/env ruby
require 'slimview'
require 'mister_bin'

runner = MisterBin::Runner.new
runner.route_all to: Slimview::Command

begin
  exit runner.run ARGV
rescue Interrupt
  puts "\nGoodbye"
  exit 1
rescue => e
  if ENV['DEBUG']
    puts e.backtrace.reverse
    puts
  end
  puts "ERROR: #{e.class}"
  puts e.message
  exit 1
end
